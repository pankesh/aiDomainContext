# Database
DATABASE_URL=postgresql+asyncpg://aidomaincontext:localdev@localhost:5432/aidomaincontext

# Redis
REDIS_URL=redis://localhost:6379

# Connector credential encryption key (generate your own for production):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-in-production

# Google (embeddings)
GOOGLE_API_KEY=AIza...

# Google OAuth (Gmail connector)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback

# Anthropic (generation)
ANTHROPIC_API_KEY=sk-ant-...

# Hugging Face (model downloads — optional, suppresses rate-limit warnings)
HF_TOKEN=hf_...

# Embedding model
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768

# Chunking
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_FRACTION=0.1

# Retrieval
SEARCH_TOP_K=40
RERANK_TOP_K=5
CONTEXT_TOKEN_BUDGET=8000
